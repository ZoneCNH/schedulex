{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "schedulex release manifest",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "module",
    "version",
    "layer",
    "role",
    "goal_id",
    "generated_at",
    "artifacts",
    "verification"
  ],
  "properties": {
    "module": { "const": "github.com/ZoneCNH/schedulex" },
    "version": { "const": "v0.1.0" },
    "layer": { "const": "L1" },
    "role": { "const": "deterministic_scheduler" },
    "goal_id": { "const": "GOAL-20260604-SCHEDULEX-001" },
    "generated_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["commit", "tree", "workspace_status"],
      "properties": {
        "commit": { "type": "string" },
        "tree": { "type": "string" },
        "workspace_status": { "type": "string" }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
